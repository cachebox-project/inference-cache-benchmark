#     pods=($(kubectl "${kc_args[@]}" -n ic-smoke get pod \
#         -l app=vllm-engine -o jsonpath='{.items[*].metadata.name}' 2>/dev/null))
#     # Static svc-targeted PFs that should always be present.
#     PF_SPECS=(
#         "38001|-n inference-cache port-forward svc/inference-cache-server :8080"
#         "38002|-n inference-cache port-forward svc/inference-cache-server :9090"
#         "38005|-n gpu-baseline    port-forward svc/vllm-baseline          :8000"
#     )
#     # ZMQ event port (15001+i) and HTTP serve port (38010+i) per replica.
#     local i=0 pod
#     for pod in "${pods[@]}"; do
#         PF_SPECS+=("$((15001+i))|-n ic-smoke port-forward pod/$pod :5557")
#         PF_SPECS+=("$((38010+i))|-n ic-smoke port-forward pod/$pod :8000")
